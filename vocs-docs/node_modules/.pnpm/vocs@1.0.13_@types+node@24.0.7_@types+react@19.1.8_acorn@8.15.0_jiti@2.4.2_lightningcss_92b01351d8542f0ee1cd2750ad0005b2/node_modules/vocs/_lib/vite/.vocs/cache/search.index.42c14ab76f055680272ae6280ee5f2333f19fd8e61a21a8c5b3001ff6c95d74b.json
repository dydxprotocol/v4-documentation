D50\\\">TxHash</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">, </span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\">NodeError</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">&gt;</span></span></code></pre></div><div data-title=\\\"API\\\"><pre><code class=\\\"language-url\\\">/dydxprotocol.clob.Msg/BatchCancel\\n</code></pre></div></div>\\n<details><summary>Unification Plan</summary><ul>\\n<li><code>TxOptions</code> is not available in Rust</li>\\n</ul></details>\\n\",\"id\":\"docs/pages/node-client/private/batch_cancel_orders.mdx#method-declaration\",\"isPage\":false,\"text\":\"\\nasync def batch_cancel_orders(\\n    self,\\n    wallet: Wallet,\\n    subaccount_id: SubaccountId,\\n    short_term_cancels: List[OrderBatch],\\n    good_til_block: int,\\n    tx_options: Optional[TxOptions] = None,\\n)async batchCancelShortTermOrdersWithMarketId(\\n  subaccount: SubaccountInfo,\\n  shortTermOrders: OrderBatchWithMarketId[],\\n  goodTilBlock: number,\\n  broadcastMode?: BroadcastMode,\\n): Promise&lt;BroadcastTxAsyncResponse | BroadcastTxSyncResponse | IndexedTx&gt;pub async fn batch_cancel_orders(\\n    &amp;mut self,\\n    account: &amp;mut Account,\\n    subaccount: Subaccount,\\n    short_term_cancels: Vec&lt;OrderBatch&gt;,\\n    until_block: Height,\\n) -&gt; Result&lt;TxHash, NodeError&gt;/dydxprotocol.clob.Msg/BatchCancel\\n\\nUnification Plan\\nTxOptions is not available in Rust\\n\\n\",\"title\":\"Method Declaration\",\"titles\":[null,null,\"Batch Cancel Orders\"]},{\"href\":\"/node-client/private/batch_cancel_orders#parameters\",\"html\":\"\\n<table><thead><tr><th>Parameter</th><th>Location</th><th>Type</th><th>Required</th><th>Description</th></tr></thead><tbody><tr><td><code>wallet</code></td><td>query</td><td><a href=\\\"/types/wallet\\\">Wallet</a></td><td>true</td><td>The wallet to use for signing the transaction.</td></tr><tr><td><code>subaccount_id</code></td><td>query</td><td><a href=\\\"/types/subaccount_id\\\">Sub