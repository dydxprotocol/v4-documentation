an class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    .account</span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    .get_subaccount_perpetual_positions(address, </span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">0</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">, PositionStatus.</span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">OPEN</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">) </span></span></code></pre></div><div data-title=\\\"TypeScript\\\"><pre class=\\\"shiki shiki-themes github-light github-dark-dimmed\\\" style=\\\"background-color:#fff;--shiki-dark-bg:#22272e;color:#24292e;--shiki-dark:#adbac7\\\" tabindex=\\\"0\\\" data-title=\\\"TypeScript\\\" data-lang=\\\"typescript\\\"><code><span class=\\\"line\\\"><span style=\\\"color:#6A737D;--shiki-dark:#768390\\\">// Fetch all subaccount &#x27;0&#x27; positions. </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">const</span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\"> response</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> =</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> await</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> indexer</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">  .account</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">  .</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">getSubaccountPerpetualPositions</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(</span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">ADDRESS</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">, </span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">0</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">);</span></span>\\n<span class=\\\"line\\\" data-empty-line=\\\"true\\\"> </span>\\n<span class=\\\"line\\\"><span style=\\\"color:#6A737D;--shiki-dark:#768390\\\">// Fetch only open positions. </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">const</span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\"> response</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> =</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> await</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> indexer</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">  .account</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">  .</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">getSubaccountPerpetualPositions</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(</span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">ADDRESS</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">, </span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">0</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">, PositionStatus.</span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">OPEN</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">);</span></span></code></pre></div><div data-title=\\\"Rust\\\"><pre class=\\\"shiki shiki-themes github-light github-dark-dimmed has-focused\\\" style=\\\"background-color:#fff;--shiki-dark-bg:#22272e;color:#24292e;--shiki-dark:#adbac7\\\" tabindex=\\\"0\\\" data-title=\\\"Rust\\\" data-lang=\\\"rust\\\"><code><span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">use</span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\"> dydx</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">::</span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\">indexer</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">::</span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\">PerpetualPositionStatus</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">; </span></span>\\n<span class=\\\"line\\\" data-empty-line=\\\"true\\\"> </span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#6A737D;--shiki-dark:#768390\\\">// Fetch all subaccount &#x27;0&#x27; positions.</span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">let</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> positions </span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">=</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> indexer </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    .</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">accounts</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">() </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    .</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">get_subaccount_perpetual_positions</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">&amp;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">subaccount, </span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\">None</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">) </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    .await?</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">; </span></span>\\n<span class=\\\"line\\\" data-empty-line=\\\"true\\\"> </span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#6A737D;--shiki-dark:#768390\\\">// Fetch only open positions. </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">let</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> opts </span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">=</span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\"> ListPositionsOpts</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> { </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    status</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">:</span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\"> PerpetualPositionStatus</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">::</span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\">Open</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">.</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">into</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(), </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    ..</span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\">Default</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">::</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">default</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">() </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">}; </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">let</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> positions </span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">=</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> indexer  </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    .</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">accounts</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">()  </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    .</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">get_subaccount_perpetual_positions</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">&amp;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">subaccount, </span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\">Some</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(opts)) </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    .await?</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">;  </span></span></code></pre></div></div>\\n<p>See the <a href=\\\"/indexer-client/http/accounts/list_positions\\\">API reference</a> for the complete method definition.</p>\\n\",\"id\":\"docs/pages/interaction/data/market.mdx#list-positions\",\"isPage\":false,\"text\":\"\\nAssets are used to trade and manage (perpetual) positions opened and closed by issuing orders. See the example below on how to check your perpetual positions.\\nfrom dydx_v4_client.indexer.rest.constants import PositionStatus\\n \\n# Fetch all subaccount &#x27;0&#x27; positions.\\nperpetual_positions_response = await indexer \\n    .account \\n    .get_subaccount_perpetual_positions(ADDRESS, 0) \\n \\n# Fetch only open positions. \\nperpetual_positions_response = await indexer\\n    .account\\n    .get_subaccount_perpetual_positions(address, 0, PositionStatus.OPEN) // Fetch all subaccount &#x27;0&#x27; positions. \\nconst response = await indexer\\n  .account\\n  .getSubaccountPerpetualPositions(ADDRESS, 0);\\n \\n// Fetch only open positions. \\nconst response = await indexer\\n  .account\\n  .getSubaccountPerpetualPositions(ADDRESS, 0, PositionStatus.OPEN);use dydx::indexer::PerpetualPositionStatus; \\n \\n// Fetch all subaccount &#x27;0&#x27; positions.\\nlet positions = indexer \\n    .accounts() \\n    .get_subaccount_perpetual_positions(&amp;subaccount, None) \\n    .await?; \\n \\n// Fetch only open positions. \\nlet opts = ListPositionsOpts { \\n    status: PerpetualPositionStatus::Open.into(), \\n    ..Default::default() \\n}; \\nlet positions = indexer  \\n    .accounts()  \\n    .get_subaccount_perpetual_positions(&amp;subaccount, Some(opts)) \\n    .await?;  \\nSee the API reference for the complete method definition.\\n\",\"title\":\"List Positions\",\"titles\":[\"Trading Data\"]},{\"href\":\"/interaction/data/market#market-list\",\"html\":\"\\n<p>A market (sometimes referred by the ticker name, e.g., <code>ETH-USD</code>) is associated with a perpetual and it is the place where trading happens.\\nTo fetch the available markets see the code below.</p>\\n<div class=\\\"code-group\\\"><div data-title=\\\"Python\\\"><pre class=\\\"shiki shiki-themes github-light github-dark-dimmed has-focused\\\" style=\\\"background-color:#fff;--shiki-dark-bg:#22272e;color:#24292e;--shiki-dark:#adbac7\\\" tabindex=\\\"0\\\" data-title=\\\"Python\\\" data-lang=\\\"python\\\"><code><span class=\\\"line focused\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">response </span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">=</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> await</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> indexer.markets.get_perpetual_markets() </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">print</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(response[</span><span style=\\\"color:#032F62;--shiki-dark:#96D0FF\\\">&quot;markets&quot;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">]) </span></span></code></pre></div><div data-title=\\\"TypeScript\\\"><pre class=\\\"shiki shiki-themes github-light github-dark-dimmed has-focused\\\" style=\\\"background-color:#fff;--shiki-dark-bg:#22272e;color:#24292e;--shiki-dark:#adbac7\\\" tabindex=\\\"0\\\" data-title=\\\"TypeScript\\\" data-lang=\\\"typescript\\\"><code><span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">const</span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\"> response</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> =</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> await</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> indexer.markets.</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">getPerpetualMarkets</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(); </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">console.</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">log</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(response.markets); </span></span></code></pre></div><div data-title=\\\"Rust\\\"><pre class=\\\"shiki shiki-themes github-light github-dark-dimmed has-focused\\\" style=\\\"background-color:#fff;--shiki-dark-bg:#22272e;color:#24292e;--shiki-dark:#adbac7\\\" tabindex=\\\"0\\\" data-title=\\\"Rust\\\" data-lang=\\\"rust\\\"><code><span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">let</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> markets </span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">=</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> indexer </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">        .</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">markets</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">() </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">        .</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">get_perpetual_markets</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(</span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\">None</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">) </span><span style=\\\"color:#6A737D;--shiki-dark:#768390\\\">// `None`: Use default options.  </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">        .await?</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">; </span></span>\\n<span class=\\\"line focused\\\"><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">println!</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(</span><span style=\\\"color:#032F62;--shiki-dark:#96D0FF\\\">&quot;{markets:?}&quot;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">); </span></span></code></pre></div></div>\\n<p>See the <a href=\\\"/indexer-client/http/markets/get_perpetual_markets\\\">API reference</a> for the complete method definition.</p>\\n\",\"id\":\"docs/pages/interaction/data/market.mdx#market-list\",\"isPage\":false,\"text\":\"\\nA market (sometimes referred by the ticker name, e.g., ETH-USD) is associated with a perpetual and it is the place where trading happens.\\nTo fetch the available markets see the code below.\\nresponse = await indexer.markets.get_perpetual_markets() \\nprint(response[&quot;markets&quot;]) const response = await indexer.markets.getPerpetualMarkets(); \\nconsole.log(response.markets); let markets = indexer \\n        .markets() \\n        .get_perpetual_markets(None) // `None`: Use default options.  \\n        .await?; \\nprintln!(&quot;{markets:?}&quot;); \\nSee the API reference for the complete method definition.\\n\",\"title\":\"Market List\",\"titles\":[\"Trading Data\"]},{\"href\":\"/interaction/data/market#list-orders\",\"html\":\"\\n<p>Retrieve orders for a specific subaccount, with various filtering options to narrow down the results based on order characteristics.</p>\\n<aside data-callout=\\\"info\\\"><p>It is recommended to set specific clientID&#x27;s when placing different orders, which will be useful to retrieve back a specific order on the <code>v4/orders</code> endpoint</p></aside>\\n<div class=\\\"code-group\\\"><div data-title=\\\"Python\\\"><pre class=\\\"shiki shiki-themes github-light github-dark-dimmed has-focused\\\" style=\\\"background-color:#fff;--shiki-dark-bg:#22272e;color:#24292e;--shiki-dark:#adbac7\\\" tabindex=\\\"0\\\" data-title=\\\"Python\\\" data-lang=\\\"python\\\"><code><span class=\\\"line focused\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">orders_response </span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">=</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> indexer.account.get_subaccount_orders(address, </span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">0</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">) </span></span></code></pre></div><div data-title=\\\"TypeScript\\\"><pre class=\\\"shiki shiki-themes github-light github-dark-dimmed\\\" style=\\\"background-color:#fff;--shiki-dark-bg:#22272e;color:#24292e;--shiki-dark:#adbac7\\\" tabindex=\\\"0\\\" data-title=\\\"TypeScript\\\" data-lang=\\\"typescript\\\"><code><span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">const</span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\"> response</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> =</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> await</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> indexer.account.</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">getSubaccountOrders</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(</span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">ADDRESS</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">, </span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">0</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">);</span></span></code></pre></div><div data-title=\\\"Rust\\\"><pre class=\\\"shiki shiki-themes github-light github-dark-dimmed has-focused\\\" style=\\\"background-color:#fff;--shiki-dark-bg:#22272e;color:#24292e;--shiki-dark:#adbac7\\\" tabindex=\\\