et,\\n    sender: str,\\n    recipient_subaccount: SubaccountId,\\n    asset_id: int,\\n    quantums: int,\\n)async deposit(\\n  subaccount: SubaccountInfo,\\n  assetId: number,\\n  quantums: Long,\\n  broadcastMode?: BroadcastMode,\\n): Promise&lt;BroadcastTxAsyncResponse | BroadcastTxSyncResponse | IndexedTx&gt;pub async fn deposit(\\n    &amp;mut self,\\n    account: &amp;mut Account,\\n    sender: Address,\\n    recipient: Subaccount,\\n    amount: impl Into&lt;Usdc&gt;,\\n) -&gt; Result&lt;TxHash, NodeError&gt;/dydxprotocol.sending.Msg/DepositToSubaccount\\n\\nUnification Plan\\n\",\"title\":\"Method Declaration\",\"titles\":[null,null,\"Deposit\"]},{\"href\":\"/node-client/private/deposit#parameters\",\"html\":\"\\n<table><thead><tr><th>Parameter</th><th>Location</th><th>Type</th><th>Required</th><th>Description</th></tr></thead><tbody><tr><td><code>wallet</code></td><td>query</td><td><a href=\\\"/types/wallet\\\">Wallet</a></td><td>true</td><td>The wallet to use for signing the transaction.</td></tr><tr><td><code>sender</code></td><td>query</td><td>string</td><td>true</td><td>The sender address.</td></tr><tr><td><code>recipient_subaccount</code></td><td>query</td><td><a href=\\\"/types/Subaccount_id\\\">SubaccountId</a></td><td>true</td><td>The recipient subaccount ID.</td></tr><tr><td><code>asset_id</code></td><td>query</td><td><a href=\\\"/types/asset_id_node\\\">AssetId</a></td><td>true</td><td>The asset ID.</td></tr><tr><td><code>quantums</code></td><td>query</td><td>int</td><td>true</td><td>The amount of quantums to deposit. <a href=\\\"../../concepts/trading/quantums#quantums\\\">See more about quantums</a></td></tr></tbody></table>\\n\",\"id\":\"docs/pages/node-client/private/deposit.mdx#parameters\",\"isPage\":false,\"text\":\"\\nParameterLocationTypeRequiredDescriptionwalletqueryWallettrueThe wallet to use for signing the transaction.senderquerystringtrueThe sender address.recipient_subaccountquerySubaccountIdtrueThe recipient subaccount ID.asset_idqueryAssetIdtrueThe asset ID.quantumsqueryinttrueThe amount of quantums to deposit. See more about quantums\\n\",\"title\":\"Parameters\",\"titles\":[null,null,\"Deposit\"]},{\"href\":\"/node-client/private/deposit#response\",\"html\":\"\\n<table><thead><tr><th>Status</th><th>Meaning</th><th>Schema</th><th>Description</th></tr></thead><tbody><tr><td><code>200</code></td><td><a href=\\\"/types/ok\\\">OK</a></td><td><a href=\\\"/types/tx_hash\\\">TxHash</a></td><td></td></tr><tr><td><code>400</code></td><td><a href=\\\"/types/bad-request\\\">Bad Request</a></td><td></td><td>The request was malformed or invalid.</td></tr><tr><td><code>404</code></td><td><a href=\\\"/types/not-found\\\">Not Found</a></td><td></td><td>The subaccount was not found.</td></tr></tbody></table>\",\"id\":\"docs/pages/node-client/private/deposit.mdx#response\",\"isPage\":false,\"text\":\"\\nStatusMeaningSchemaDescription200OKTxHash400Bad RequestThe request was malformed or invalid.404Not FoundThe subaccount was not found.\",\"title\":\"Response\",\"titles\":[null,null,\"Deposit\"]}]}}"
