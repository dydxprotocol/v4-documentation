an style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">.</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">place_order</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">&amp;mut</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> account, order)</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">.await?</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">; </span></span></code></pre></div></div></div></div>\",\"id\":\"docs/pages/interaction/permissioned-keys/#using-the-authenticator\",\"isPage\":false,\"text\":\"Having the authenticator ID, the trader can now use it to perform the allowed actions.In this example, the trader can use the authenticator to issue orders on the behalf of the owner.id = ... # authenticator ID \\n# Create the order ID, using the owner address \\norder_id = market.order_id( \\n    OWNER_ADDRESS, # address \\n    0, # subaccount number\\n    random.randint(0, 100000000), # client ID, can be random\\n    OrderFlags.SHORT_TERM # short-term order\\n) \\n# Create the order as usual \\norder = market.order( \\n    order_id, \\n    # ...\\n) \\n# The TxOptions should have the authenticator ID to be used. \\ntx_options = TxOptions([id], wallet.sequence, wallet.account_number) \\n# Place the order. \\nplace = await node.place_order(wallet, order, tx_options) const client = await CompositeClient.connect(network);\\nconst wallet = await LocalWallet.fromMnemonic(DYDX_TEST_MNEMONIC_2, BECH32_PREFIX);\\nconst subaccount = new SubaccountInfo(wallet, 0);\\nconst ownerSubaccount = ...;\\nconst id = ...; // authenticator ID\\nconst currentBlock = await client.validatorClient.get.latestBlockHeight();\\n// Place an order using the authenticator. \\nconst tx = await client.placeShortTermOrder( \\n  subaccount, \\n  &#x27;ETH-USD&#x27;,\\n  OrderSide.BUY,\\n  1000,\\n  0.01,\\n  Math.floor(Math.random() * 10000), // client ID\\n  currentBlock + 10,\\n  Order_TimeInForce.TIME_IN_FORCE_UNSPECIFIED,\\n  false,\\n  undefined,\\n  { \\n    authenticators: [id], \\n    accountForOrder: ownerSubaccount, \\n  }, \\n); // Create a `PublicAccount` representing the owner. \\nlet owner_account =\\n    PublicAccount::updated(owner_address.clone(), &amp;mut client).await?; \\n// Register the public account. \\naccount \\n    .authenticators_mut() \\n    .add_authenticator(external_account, id); \\n \\n// Create an order for the owner subaccount. \\nlet owner_subaccount = Subaccount { \\n    address: owner_address.clone(), \\n    number: 0.try_into()?,\\n}; \\nlet (_, order) = OrderBuilder::new(market, owner_subaccount) \\n    //...\\n    .build(123456)?;\\n \\n// Place an order using the authenticator. \\nlet tx_hash = client.place_order(&amp;mut account, order).await?; \",\"title\":\"Using the authenticator\",\"titles\":[\"Permissioned Keys\",\"Trader\"]}]}}"
