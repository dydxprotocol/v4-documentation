C5;--shiki-dark:#6CB6FF\\\"> Promise</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">&lt;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">Account</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">&gt;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">,</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">): </span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">Promise</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">&lt;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">StdFee</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">&gt;</span></span></code></pre></div><div data-title=\\\"Rust\\\"><pre class=\\\"shiki shiki-themes github-light github-dark-dimmed\\\" style=\\\"background-color:#fff;--shiki-dark-bg:#22272e;color:#24292e;--shiki-dark:#adbac7\\\" tabindex=\\\"0\\\" data-title=\\\"Rust\\\" data-lang=\\\"rust\\\"><code><span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">pub</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> async</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> fn</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\"> simulate</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">&amp;mut</span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\"> self</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">, tx_raw</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">:</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> &amp;</span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\">Raw</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">) </span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">-&gt;</span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\"> Result</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">&lt;</span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\">GasInfo</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">, </span><span style=\\\"color:#6F42C1;--shiki-dark:#F69D50\\\">NodeError</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">&gt;</span></span></code></pre></div><div data-title=\\\"API\\\"><pre><code class=\\\"language-url\\\"></code></pre></div></div>\\n<details><summary>Unification Plan</summary><ul>\\n<li>Some extra parameters in TypeScript? What to do with them?</li>\\n</ul></details>\\n\",\"id\":\"docs/pages/node-client/private/simulate.mdx#method-declaration\",\"isPage\":false,\"text\":\"\\nasync def simulate(self, transaction: Tx)async simulate(\\n    wallet: LocalWallet,\\n    messaging: () =&gt; Promise&lt;EncodeObject[]&gt;,\\n    gasPrice: GasPrice = this.getGasPrice(),\\n    memo?: string,\\n    account?: () =&gt; Promise&lt;Account&gt;,\\n): Promise&lt;StdFee&gt;pub async fn simulate(&amp;mut self, tx_raw: &amp;Raw) -&gt; Result&lt;GasInfo, NodeError&gt;\\nUnification Plan\\nSome extra parameters in TypeScript? What to do with them?\\n\\n\",\"title\":\"Method Declaration\",\"titles\":[null,null,\"Simulate\"]},{\"href\":\"/node-client/private/simulate#parameters\",\"html\":\"\\n<table><thead><tr><th>Parameter</th><th>Location</th><th>Type</th><th>Required</th><th>Description</th></tr></thead><tbody><tr><td><code>transaction</code></td><td>query</td><td><a href=\\\"/types/tx\\\">Tx</a></td><td>true</td><td>The transaction to simulate.</td></tr></tbody></table>\\n\",\"id\":\"docs/pages/node-client/private/simulate.mdx#parameters\",\"isPage\":false,\"text\":\"\\nParameterLocationTypeRequiredDescriptiontransactionqueryTxtrueThe transaction to simulate.\\n\",\"title\":\"Parameters\",\"titles\":[null,null,\"Simulate\"]},{\"href\":\"/node-client/private/simulate#response\",\"html\":\"\\n<table><thead><tr><th>Status</th><th>Meaning</th><th>Schema</th><th></th></tr></thead><tbody><tr><td><code>200</code></td><td><a href=\\\"/types/ok\\\